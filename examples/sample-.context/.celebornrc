{
  "journal_keep_entries": 20,
  "state_max_lines": 120,
  "search_default_limit": 8,
  "secret_patterns": [
    "AKIA[0-9A-Z]{16}",
    "sk-[A-Za-z0-9]{20,}",
    "ghp_[A-Za-z0-9]{36}",
    "xox[baprs]-[0-9A-Za-z-]{10,}",
    "-----BEGIN [A-Z ]*PRIVATE KEY-----",
    "AIza[0-9A-Za-z_-]{35}"
  ]
}
