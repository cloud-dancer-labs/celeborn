# Point the board at any repo's derived task data (absolute path).
# Defaults to ../.context/tasks.json (the board assumed to live at <repo>/board/).
# CELEBORN_TASKS_JSON=/absolute/path/to/.context/tasks.json

# The Celeborn CLI the board's write actions (add / reorder / move / handoff) shell out to.
# Defaults to `celeborn` on PATH; set this for a non-standard install.
# CELEBORN_BIN=/absolute/path/to/celeborn
