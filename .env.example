# Copy to .env and fill in. .env is gitignored; this template is safe to commit.
# Stripe keys come from https://dashboard.stripe.com/apikeys (use TEST keys in dev).
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# From the Stripe webhook endpoint (`stripe listen` prints one, or the dashboard).
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring Price IDs created by scripts/stripe_bootstrap.sh (or the dashboard).
# The webhook maps a subscription's price -> tier via the price's metadata[tier]; these env vars are the
# fallback mapping and are what create-checkout uses to pick the price for `celeborn upgrade`.
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# Optional: override the pages Checkout / the billing portal return to (defaults under celeborn.dev).
# CELEBORN_SITE_URL=https://celeborn.dev
# CELEBORN_CHECKOUT_SUCCESS_URL=https://celeborn.dev/welcome?upgraded=1
# CELEBORN_CHECKOUT_CANCEL_URL=https://celeborn.dev/pricing
# CELEBORN_PORTAL_RETURN_URL=https://celeborn.dev/account
