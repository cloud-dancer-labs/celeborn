{
  "_comment": "Celeborn adapter for the OpenAI Codex CLI. Codex's lifecycle-hooks system uses the same event names as Claude Code (SessionStart / UserPromptSubmit / Stop / PreCompact / SessionEnd). Install with scripts/install.sh, which writes this to ~/.codex/hooks/celeborn.json. If your Codex build only supports the [hooks] table in config.toml, translate these entries there (same shape). Requires celeborn on PATH.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.codex/skills/celeborn-codex/scripts/codex_celeborn.py\" session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.codex/skills/celeborn-codex/scripts/codex_celeborn.py\" user-prompt-submit",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.codex/skills/celeborn-codex/scripts/codex_celeborn.py\" stop",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.codex/skills/celeborn-codex/scripts/codex_celeborn.py\" pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.codex/skills/celeborn-codex/scripts/codex_celeborn.py\" session-end",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
