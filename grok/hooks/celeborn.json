{
  "_comment": "Celeborn adapter for Grok Build. Install with scripts/install.sh. Requires celeborn on PATH.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.grok/skills/celeborn-grok/scripts/grok_celeborn.py\" session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.grok/skills/celeborn-grok/scripts/grok_celeborn.py\" user-prompt-submit",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.grok/skills/celeborn-grok/scripts/grok_celeborn.py\" stop",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.grok/skills/celeborn-grok/scripts/grok_celeborn.py\" pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/.grok/skills/celeborn-grok/scripts/grok_celeborn.py\" session-end",
            "timeout": 15
          }
        ]
      }
    ]
  }
}